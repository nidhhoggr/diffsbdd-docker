# Rename to `.env` to make `docker compose` GPU-aware automatically.
# (cp .env.gpu.sample .env)  —  Compose auto-loads `.env` from the project dir.

COMPOSE_FILE=docker-compose.yml:docker-compose.gpu.yml

# Which conda env file the image is built from (path is inside the image).
#   /tmp/environment.gpu.yaml  -> upstream CUDA 11.8 build
#   /tmp/environment.cpu.yaml  -> CPU-only
ENV_FILE=/tmp/environment.gpu.yaml
